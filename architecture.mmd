%%{init: {'theme': 'base', 'themeVariables': {'fontSize': '14px', 'primaryColor': '#E8F5E9', 'primaryBorderColor': '#4CAF50', 'lineColor': '#666', 'secondaryColor': '#FFF3E0', 'tertiaryColor': '#E3F2FD'}}}%%
flowchart TD
    START(["🎯 시뮬레이션 시작"])
    INIT["🔧 초기화\n에이전트 5개 병렬 생성\n균형형 / 성과형 / 사교형 / 정치형 / 워라밸형\n동일 시드 / 시나리오"]
    LOOP{"📅 매일 반복\nDay 1 ~ 7,300\n매일"}
    WEEKEND{"주말?"}
    WEEKEND_ACT["성향별 가중치로만\n자동 선택"]
    PLAN_CHECK{"행동 계획\n남아있음?"}
    REFLECT_CHECK{"90일\n경과?"}
    REFLECT["🔍 자기성찰 Reflection\n\nGPT-4.1 으로 자기 평가 후\n\n① 승진 요건 vs 현재 스탯 갭\n② 지난 90일 행동 평가\n③ 문제점 진단 / 원인 분석"]
    BATCH["📋 행동 계획\n\nGPT-4.1-mini 호출\n\n현재 상태(스탯 8종) + 성향 설명 + 메모리를 보고\n30일치 행동 계획 생성\nThought → Day 1 ~ Day 30"]
    RANDOM_EVENT["🎲 자연 발생\n\n성향별 가중치에 따라\n회사/팀/개인 이벤트가\n확률적으로 발생"]
    ACTIONS["행동 실행\n야근 / 상사와 점심 / 동료 돕기 / 정치질 / 이직 준비 / 휴가 / 자기계발 / 플젝 집중"]
    ENV["📊 환경 처리\n\n① 행동 효과 적용 + 성향 배율\n② 자연 회복 / 저하\n③ 랜덤 이벤트 판정 + 효과\n④ 수치 범위 클램프\n⑤ 이직 판정 (비종료)\n⑥ 승진 판정"]
    MEMORY["📝 기억 저장\n\n에피소딕 메모리 (capacity=50)\n중요 사건만 선별 저장\n승진/해고위기/이벤트/번아웃"]
    EXIT_CHECK{"종료 판정"}

    BURNOUT["🔴 번아웃\n스트레스 90+\n체력 10 이하\n30일 지속"]
    CHRONIC["🟠 만성 스트레스\n스트레스 85+\n90일 이상\n지속"]
    FORCED["🟡 권고사직\n경력 5년+\n성과/승진\n미달"]
    FIRED["🔴 해고\n성과 바닥\n상사 신뢰 0"]
    VOLUNTARY["🟢 희망퇴직\n경력 12년+\n스트레스 높고\n체력 낮으면\n확률 상승"]
    RETIRE["🏆 정년퇴직\n20년\n(7,300일)\n생존!"]

    JOB_CHANGE["🔄 이직\n연봉 +30~50%\n스킬/성과/스트레스 리셋\n직급 유지 / 인간관계 초기화"]
    FINAL["🏁 최종 결과\n\n생존 일수\n최종 직급 / 연봉\n→ 성향별 비교 → 시각화"]

    START --> INIT
    INIT --> LOOP
    LOOP --> WEEKEND

    WEEKEND -- "주말" --> WEEKEND_ACT
    WEEKEND_ACT -- "평일과 합류" --> ACTIONS

    WEEKEND -- "평일" --> PLAN_CHECK
    PLAN_CHECK -- "남음" --> ACTIONS
    PLAN_CHECK -- "소진" --> REFLECT_CHECK

    REFLECT_CHECK -- "예" --> REFLECT
    REFLECT_CHECK -- "아니오" --> BATCH
    REFLECT --> BATCH
    BATCH --> ACTIONS

    ACTIONS --> ENV
    RANDOM_EVENT -. "확률 발생" .-> ENV
    ENV --> MEMORY
    MEMORY --> EXIT_CHECK

    EXIT_CHECK -- "생존" --> LOOP
    EXIT_CHECK -- "번아웃" --> BURNOUT
    EXIT_CHECK -- "만성 스트레스" --> CHRONIC
    EXIT_CHECK -- "권고사직" --> FORCED
    EXIT_CHECK -- "해고" --> FIRED
    EXIT_CHECK -- "희망퇴직" --> VOLUNTARY
    EXIT_CHECK -- "20년 생존" --> RETIRE

    BURNOUT --> FINAL
    CHRONIC --> FINAL
    FORCED --> FINAL
    FIRED --> FINAL
    VOLUNTARY --> FINAL
    RETIRE --> FINAL

    ENV -. "이직 조건 충족" .-> JOB_CHANGE
    JOB_CHANGE -. "새 회사에서 계속" .-> LOOP

    classDef greenNode fill:#E8F5E9,stroke:#4CAF50,stroke-width:2px,color:#1B5E20
    classDef orangeNode fill:#FFF3E0,stroke:#FF9800,stroke-width:2px,color:#E65100
    classDef blueNode fill:#E3F2FD,stroke:#2196F3,stroke-width:2px,color:#0D47A1
    classDef pinkNode fill:#FCE4EC,stroke:#E91E63,stroke-width:2px,color:#880E4F
    classDef yellowNode fill:#FFFDE7,stroke:#FBC02D,stroke-width:2px,color:#F57F17
    classDef redNode fill:#FFEBEE,stroke:#F44336,stroke-width:2px,color:#B71C1C
    classDef greenEndNode fill:#E8F5E9,stroke:#4CAF50,stroke-width:2px,color:#1B5E20
    classDef purpleNode fill:#F3E5F5,stroke:#9C27B0,stroke-width:2px,color:#4A148C

    class START,INIT greenNode
    class REFLECT,BATCH orangeNode
    class RANDOM_EVENT blueNode
    class ACTIONS pinkNode
    class ENV,MEMORY yellowNode
    class BURNOUT,CHRONIC,FORCED,FIRED redNode
    class VOLUNTARY,RETIRE greenEndNode
    class JOB_CHANGE purpleNode
    class FINAL blueNode
