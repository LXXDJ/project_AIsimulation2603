graph TD
    START(["🚀 시뮬레이션 시작<br/>main.py :: _run_one()"]) --> INIT["객체 생성<br/>main.py :: _run_one()<br/>━━━━━━━━━━━━<br/>llm = LLMClient(model=MODEL_DECISION)<br/>llm_reflect = LLMClient(model=MODEL_REFLECTION)<br/>agent = ReActAgent(llm, personality, llm_reflect)<br/>env = CompanyEnvironment(seed, personality, max_days)"]

    INIT -->|"agent, env,<br/>max_days=7300,<br/>decision_interval=30"| SIM["시뮬레이션 루프 시작<br/>runner/simulation.py :: run_simulation()"]

    SIM --> LOOP{"매일 반복 (Day 1 ~ 7300)<br/>for day in range(1, max_days+1)"}

    LOOP -->|"(day-1) % 7 >= 5"| WE["주말 활동 선택<br/>env.step_weekend()<br/>━━━━━━━━━━━━<br/>personality.weekend_weights로<br/>가중치 랜덤 선택 → 스탯 반영<br/>━━━━━━━━━━━━<br/>→ state, observation, chosen_activity"]
    LOOP -->|"평일"| BATCH_Q{"30일 행동 계획 소진됨?<br/>if not pending_actions"}

    BATCH_Q -->|"False (남은 계획 있음)"| POP["오늘 행동 꺼내기<br/>action = pending_actions.pop(0)"]
    BATCH_Q -->|"True (30일 소진)"| REFLECT_Q{"자기성찰 실행 조건 확인<br/>Reflection 모델 있는가?<br/>마지막 성찰 후 90일 경과했는가?<br/>━━━━━━━━━━━━<br/>if agent.llm_reflect<br/>and day - last_reflection_day >= 90<br/>and len(agent.history) >= 90"}

    REFLECT_Q -->|"True"| REFLECT["자기성찰 (Reflection)<br/>agent.reflect(state, window=90,<br/>    promotion_requirements=env.promotion_requirements)<br/>━━━━━━━━━━━━<br/>LLMClient :: gpt-4.1 호출<br/>━━━━━━━━━━━━<br/>입력:<br/>· _build_promotion_gap(state, req) 승진 갭 분석<br/>· memory.to_text(n=5) 주요 기억<br/>· history[-90:] 최근 행동 기록<br/>· state.to_observation() 현재 상태<br/>━━━━━━━━━━━━<br/>출력: 평가 + 문제점 + 처방<br/>→ self._reflection에 저장"]

    REFLECT_Q -->|"False"| MEMORY_BUILD
    REFLECT -->|"self._reflection 저장됨"| MEMORY_BUILD

    MEMORY_BUILD["메모리 조합<br/>agent._build_memory_section()<br/>━━━━━━━━━━━━<br/>① self._reflection → 전략 지침<br/>② memory.to_text(n=10) → 주요 경험<br/>③ compress_history(history, llm, window=30)<br/>   LLM 호출로 행동 패턴 3문장 요약<br/>━━━━━━━━━━━━<br/>→ memory_section: str"]

    MEMORY_BUILD -->|"memory_section: str"| DECIDE["30일 행동 계획 생성<br/>agent.decide_batch(state, observation, n=30)<br/>━━━━━━━━━━━━<br/>LLMClient :: gpt-4.1-mini 호출<br/>━━━━━━━━━━━━<br/>system = BATCH_SYSTEM_PROMPT.format(<br/>    personality_section, memory_section,<br/>    n=30, actions=ACTIONS)<br/>messages = [state.to_observation()]<br/>━━━━━━━━━━━━<br/>출력: Day 1~30 행동 파싱<br/>→ pending_actions: list[str]"]

    DECIDE --> POP

    POP -->|"action: str"| STEP["환경 1일 전진<br/>env.step(action)<br/>━━━━━━━━━━━━<br/>① _apply_effects(effects, action)<br/>   ACTION_EFFECTS[action] + personality.get_multiplier()<br/>② _apply_daily_drift()<br/>   energy+5, stress-2, boss-0.2,<br/>   peer-0.3, rep-0.03, skill-0.02<br/>③ roll_events(rng, personality, state)<br/>   티어별 확률 판정 → 효과 적용<br/>④ state.clamp_all() 모든 스탯 0~100 제한<br/>━━━━━━━━━━━━<br/>→ state: GameState, observation: str"]

    WE --> RECORD
    STEP --> RECORD

    RECORD["기록 저장<br/>agent.record(day, action, observation)<br/>+ _store_episode_if_important()<br/>━━━━━━━━━━━━<br/>· history.append(day, action, obs)<br/>· _classify_outcome()으로 중요도 판별<br/>  승진/이직/해고위기/이벤트 발생 시<br/>  → memory.add(Episode)"]

    RECORD --> EXIT_Q{"에이전트 생존 여부 판정<br/>해고 또는 퇴사했는가?<br/>━━━━━━━━━━━━<br/>if not state.is_alive<br/>━━━━━━━━━━━━<br/>_check_burnout(): stress≥90 and energy≤10 연속30일<br/>_check_chronic_stress(): stress≥70 누적180일<br/>_check_voluntary_retirement(): 경력12년+ 확률판정<br/>_check_fired(): perf<10 and boss<10 또는 승진미달"}

    EXIT_Q -->|"is_fired or is_resigned"| END_BAD(["시뮬레이션 종료<br/>_build_result(agent_name, state, step_logs, max_days, env)"])
    EXIT_Q -->|"is_alive"| CAREER_Q{"승진 또는 이직 조건 충족?<br/>━━━━━━━━━━━━<br/>if _check_promotion():<br/>    승진 처리<br/>elif _check_job_change():<br/>    이직 처리<br/>else:<br/>    다음 날"}

    CAREER_Q -->|"승진 조건 충족<br/>if _check_promotion()<br/>연 2회 인사시즌(1월/7월)<br/>스탯 4종 ≥ 요건 and 최소 근무일 충족"| PROMOTE["승진 처리<br/>━━━━━━━━━━━━<br/>position = POSITIONS[idx+1]<br/>salary *= raise_rate (10~50%)<br/>promotion_cooldown 설정"]
    CAREER_Q -->|"이직 준비 완료<br/>if _job_change_counter >= 30"| JOB["이직 처리<br/>env._do_job_change()<br/>━━━━━━━━━━━━<br/>market_value = skill*0.35 + perf*0.35<br/>  + rep*0.20 + political*0.10<br/>· 72+ 프리미엄 (연봉40%↑ 직급↑)<br/>· 48~71 일반 (연봉15%↑)<br/>· ~47 도피성 (연봉5%↑ 환경↓)"]
    CAREER_Q -->|"else"| NEXT["다음 날"]

    PROMOTE --> NEXT
    JOB --> NEXT
    NEXT --> LOOP
    LOOP -->|"20년 완주<br/>day > max_days"| END_GOOD(["정년퇴직 / 현직유지(임원)<br/>_build_result()"])

    %% ── 서브그래프: 스탯 목록 ──
